# ── Database ──────────────────────────────────────────────────────────
DATABASE_URL="postgresql://cosmos:cosmos@localhost:5432/cosmos_leads?schema=public"
POSTGRES_USER=cosmos
POSTGRES_PASSWORD=cosmos
POSTGRES_DB=cosmos_leads

# ── Backend ───────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=production
JWT_SECRET=replace-with-long-random-secret
JWT_EXPIRES_IN=12h

# ── Admin Seed ────────────────────────────────────────────────────────
ADMIN_EMAIL=admin@cosmos.local
ADMIN_PASSWORD=ChangeMe!123

# ── Storage ───────────────────────────────────────────────────────────
UPLOAD_DIR=uploads/incoming
EXPORT_DIR=exports/output

# ── CV/OCR Service (Python) ───────────────────────────────────────────
CV_OCR_URL=http://localhost:8000
CONFIDENCE_FALLBACK_THRESHOLD=0.85
PDF_RASTER_DPI=200

# ── Claude API ────────────────────────────────────────────────────────
CLAUDE_API_KEY=sk-ant-api03-your-key-here

# ── CORS ──────────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:5173
