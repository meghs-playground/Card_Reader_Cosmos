# ── Database ──────────────────────────────────────────────────────────
DATABASE_URL="postgresql://cosmos:cosmos@localhost:5432/cosmos_leads?schema=public"
POSTGRES_USER=cosmos
POSTGRES_PASSWORD=cosmos
POSTGRES_DB=cosmos_leads

# ── Backend ───────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=production
JWT_SECRET=replace-with-long-random-secret
JWT_EXPIRES_IN=12h

# ── Admin Seed ────────────────────────────────────────────────────────
ADMIN_EMAIL=admin@cosmos.local
ADMIN_PASSWORD=ChangeMe!123

# ── Storage ───────────────────────────────────────────────────────────
UPLOAD_DIR=uploads/incoming
EXPORT_DIR=exports/output

# ── CV/OCR Service (Python) ───────────────────────────────────────────
CV_OCR_URL=http://localhost:8000
CONFIDENCE_FALLBACK_THRESHOLD=0.85
PDF_RASTER_DPI=200

# ── Claude API (backend OCR — optional but recommended) ───────────────
# When set, the backend uses Claude Vision as the primary extraction engine
# (far more accurate than Tesseract); it falls back to the Python OCR pipeline
# automatically if the key is missing/invalid, the file is a PDF or too large,
# or the API call fails. Get a key + add credits at https://console.anthropic.com
# NOTE: this is a separate product from a Claude Pro subscription — Pro does NOT
# include API access. Keep this key on the SERVER only (never in the browser).
CLAUDE_API_KEY=sk-ant-api03-your-key-here
CLAUDE_MODEL=claude-opus-4-8

# ── Groq (free alternative AI vision engine) ──────────────────────────
# Optional: a Groq key (starts gsk_) routes extraction through Groq's Llama 4
# vision model instead of Claude — fast, generous free tier. The backend
# auto-detects the provider from the key prefix, so you can paste either a
# Groq (gsk_...) or Claude (sk-ant-...) key into the dashboard Settings block.
# If Groq renames the model, set GROQ_MODEL to a current vision model id from
# https://console.groq.com/docs/models
GROQ_API_KEY=gsk_your-groq-key-here
GROQ_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# ── CORS ──────────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:5173
