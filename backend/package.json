{
  "name": "cosmos-lip-backend",
  "version": "2.0.0",
  "description": "Cosmos Lead Intelligence Platform — Backend",
  "main": "server.js",
  "prisma": {
    "schema": "database/schema.prisma"
  },
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "prisma:generate": "prisma generate --schema=database/schema.prisma",
    "prisma:migrate": "prisma migrate dev --schema=database/schema.prisma",
    "prisma:deploy": "prisma migrate deploy --schema=database/schema.prisma",
    "seed": "node database/seed.js"
  },
  "dependencies": {
    "@prisma/client": "5.22.0",
    "axios": "1.7.9",
    "bcryptjs": "2.4.3",
    "bull": "4.16.5",
    "cors": "2.8.5",
    "csv-stringify": "6.5.2",
    "dotenv": "16.4.7",
    "exceljs": "4.4.0",
    "express": "4.21.2",
    "express-rate-limit": "7.5.0",
    "form-data": "4.0.1",
    "helmet": "8.0.0",
    "jsonwebtoken": "9.0.2",
    "morgan": "1.10.0",
    "multer": "1.4.5-lts.1"
  },
  "devDependencies": {
    "nodemon": "3.1.9",
    "prisma": "5.22.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
